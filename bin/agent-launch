    "kiro",
    "mimo",
    "opencode",
    "pi",
    "pier",
    "qwen",
    "trae",
    "cursor",
}


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    argv = list(sys.argv[1:] if argv is None else argv)
    passthrough_args: list[str] = []
    if "--" in argv:
        delimiter_index = argv.index("--")
        passthrough_args = argv[delimiter_index + 1 :]
        argv = argv[:delimiter_index]

    parser = argparse.ArgumentParser(
        prog="agent-launch",
        description="Launch local coding-agent CLIs with a shared interface.",
    )
    parser.add_argument(
        "-a",
        "--agent",
        choices=AGENT_CHOICES,
        default=os.environ.get("AGENT_LAUNCH_AGENT") or "random",
        help="Agent CLI to launch. Use random to select a concrete backend uniformly. Defaults to AGENT_LAUNCH_AGENT or random.",
    )
    parser.add_argument(
        "--agent-order",
        nargs="?",
        const="default",
        default=None,
        help=(
            "Non-interactive failover order as comma-separated agents. "
            "Use without a value for the built-in default, or set AGENT_LAUNCH_AGENT_ORDER."
        ),
    )
    parser.add_argument(
        "--prefer",
        default=None,
        help=(
            "Non-interactive preferred agents as a comma-separated list. "
            "Moves those agents to the front of the default failover order."
        ),
    )
    parser.add_argument(
        "-C",
        "--cwd",
        default=os.getcwd(),
        help="Working directory/workspace for the agent. Defaults to current directory.",
    )
    parser.add_argument(
        "--no-auto-cwd",
        action="store_true",
        help="Disable Codex working-directory routing for interactive prompts.",
    )
    parser.add_argument(
        "-p",
        "--prompt",
        default=None,
        help="Initial prompt. If omitted, remaining positional text is used.",
    )
    parser.add_argument(
        "--prompt-file",
        default=None,
        help="Read the initial prompt from a UTF-8 text file.",
    )
    parser.add_argument(
        "prompt_parts",
        nargs="*",
        help="Initial prompt text, used when --prompt is not provided.",
    )
    run_mode = parser.add_mutually_exclusive_group()
    run_mode.add_argument(
        "-i",
        "--interactive",
        action="store_true",
        help="Start interactive mode. This is the default.",
    )
    run_mode.add_argument(
        "-n",
        "--non-interactive",
        action="store_true",
        help="Run headless/non-interactively and print output.",
    )
    parser.add_argument(
        "-m",
        "--mode",
        choices=MODES,
        default=os.environ.get("AGENT_LAUNCH_MODE", "danger"),
        help="Normalized permission/interaction mode.",
    )
    parser.add_argument(
        "--model-class",
        choices=MODEL_CLASSES,
        default=None,
        help="Use the agent's normalized fast or pro model. Defaults per agent.",
    )
    parser.add_argument(
        "--model",
        default=None,
        help="Explicit backend model string. Overrides --model-class.",
    )
    parser.add_argument(
        "--thinking-level",
        "--effort",
        dest="thinking_level",
        choices=THINKING_LEVELS,
        default=None,
        help="Normalized reasoning/thinking effort for supporting backends. Defaults to AGENT_LAUNCH_THINKING_LEVEL or auto.",
    )
    parser.add_argument(
        "--no-model",
        action="store_true",
        help="Do not pass any model flag to the backend.",
    )
    parser.add_argument(
        "--resume",
        nargs="?",
        const="",
        default=None,
        help="Resume a prior session. With no value, use the backend's picker/latest behavior where available.",
    )
    parser.add_argument(
        "--continue",
        dest="continue_session",
        action="store_true",
        help="Continue the latest/current session where the selected backend supports it.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the translated command without executing it.",
    )
    parser.add_argument(
        "--attempt-timeout",
        type=float,
        default=float(os.environ.get("AGENT_LAUNCH_ATTEMPT_TIMEOUT", "0") or "0"),
        help="Timeout in seconds for each non-interactive backend attempt. Exit code 124 on timeout.",
    )
    parser.add_argument(
        "--extra",
        action="append",
        default=[],
        help="Extra raw argument chunk to append to the backend command. Prefer '--' for exact pass-through.",
    )
    parser.add_argument(
        "--print-mappings",
        action="store_true",
        help="Print normalized mode/model mappings and exit.",
    )
    args, unknown_args = parser.parse_known_args(argv)
    if args.agent not in AGENT_CHOICES:
        parser.error(f"unknown agent {args.agent!r}; expected one of: {', '.join(AGENT_CHOICES)}")
    if args.resume is not None and args.continue_session:
        parser.error("--resume and --continue cannot be used together")
    if args.prompt_file and (args.prompt is not None or args.prompt_parts):
        parser.error("--prompt-file cannot be combined with --prompt or positional prompt text")
    args.passthrough_args = unknown_args + passthrough_args
    if args.print_mappings:
        args.agent_order = None
        return args
    prefer = parse_agent_list(args.prefer or os.environ.get("AGENT_LAUNCH_PREFER"), "--prefer")
    explicit_order = parse_agent_order(args.agent_order or os.environ.get("AGENT_LAUNCH_AGENT_ORDER"))
    if prefer and explicit_order:
        parser.error("--prefer cannot be combined with --agent-order")
    agent_order = preferred_agent_order(prefer) if prefer else explicit_order
    if agent_order and not args.non_interactive:
        parser.error("--agent-order/--prefer are only supported with --non-interactive")
    args.agent_order = agent_order
    if args.agent == "random" and not args.agent_order:
        args.agent = choose_random_agent(persist=not args.dry_run)
    return args


def parse_agent_order(raw: str | None) -> tuple[str, ...] | None:
    if raw is None:
        return None
    if raw == "" or raw == "default":
        return DEFAULT_AGENT_ORDER
    agents = parse_agent_list(raw, "--agent-order")
    if not agents:
        return DEFAULT_AGENT_ORDER
    return agents


def parse_agent_list(raw: str | None, option_name: str) -> tuple[str, ...] | None:
    if raw is None:
        return None
    agents = tuple(dict.fromkeys(part.strip() for part in raw.split(",") if part.strip()))
    unknown = [agent for agent in agents if agent not in AGENTS]
    if unknown:
        expected = ", ".join(AGENTS)
        raise SystemExit(f"Unknown {option_name} agent(s): {', '.join(unknown)}; expected agents from: {expected}")
    return agents


def preferred_agent_order(preferred: tuple[str, ...] | None) -> tuple[str, ...] | None:
    if not preferred:
        return None
    return preferred + tuple(agent for agent in DEFAULT_AGENT_ORDER if agent not in preferred)


def env_key(agent: str, model_class: str) -> str:
    return f"AGENT_LAUNCH_{agent.upper()}_{model_class.upper()}_MODEL"


def resolve_model_class(agent: str, args: argparse.Namespace) -> str:
    spec = AGENTS[agent]
    model_class = args.model_class or os.environ.get("AGENT_LAUNCH_MODEL_CLASS") or spec.default_model_class
    if model_class not in MODEL_CLASSES:
        raise SystemExit(f"Unknown model class {model_class!r}; expected one of: {', '.join(MODEL_CLASSES)}")
    return model_class


def resolve_model(agent: str, args: argparse.Namespace) -> str | None:
    if args.no_model:
        return None
    if args.model:
        return args.model

    spec = AGENTS[agent]
    model_class = resolve_model_class(agent, args)
    return os.environ.get(env_key(agent, model_class)) or getattr(spec, f"{model_class}_model")


def resolve_thinking_level(args: argparse.Namespace) -> str:
    level = args.thinking_level or os.environ.get("AGENT_LAUNCH_THINKING_LEVEL") or "auto"
    if level not in THINKING_LEVELS:
        raise SystemExit(f"Unknown thinking level {level!r}; expected one of: {', '.join(THINKING_LEVELS)}")
    return level


def prompt_from(args: argparse.Namespace) -> str | None:
    if args.prompt_file is not None:
        with open(args.prompt_file, encoding="utf-8") as handle:
            return handle.read()
    if args.prompt is not None:
        return args.prompt
    if args.prompt_parts:
        return " ".join(args.prompt_parts)
    return None


def truthy_env_disabled(raw: str | None) -> bool:
    return raw is not None and raw.strip().lower() in {"0", "false", "no", "off", "disabled"}


def cwd_router_config() -> tuple[str, float]:
    model = (os.environ.get("AGENT_LAUNCH_CWD_ROUTER_MODEL") or DEFAULT_CWD_ROUTER_MODEL).strip()
    try:
        timeout = float(os.environ.get("AGENT_LAUNCH_CWD_ROUTER_TIMEOUT", "") or DEFAULT_CWD_ROUTER_TIMEOUT)
    except ValueError:
        timeout = DEFAULT_CWD_ROUTER_TIMEOUT
    return model, timeout


def directory_name_hints(prompt: str, root: str, max_depth: int = 4, limit: int = 40) -> list[str]:
    terms = {
        term
        for term in re.findall(r"[a-z0-9][a-z0-9_-]{2,}", prompt.lower())
        if term not in ROUTER_GENERIC_TERMS
    }
    if not terms:
        return []
    root = os.path.realpath(root)
    hints: list[tuple[int, int, int, str]] = []
    for current, dirs, _files in os.walk(root):
        relative = os.path.relpath(current, root)
        depth = 0 if relative == "." else relative.count(os.sep) + 1
        dirs[:] = [name for name in dirs if name not in ROUTER_IGNORED_DIRS and not name.startswith(".")]
        if depth >= max_depth:
            dirs[:] = []
        if depth == 0:
            continue
        name_terms = set(re.findall(r"[a-z0-9]+", os.path.basename(current).lower()))
        matches = len(terms & name_terms)
        if matches:
            project_markers = sum(
                os.path.exists(os.path.join(current, marker))
                for marker in (".git", "AGENTS.md", "CLAUDE.md", "README.md", "SKILL.md", "package.json", "pyproject.toml")
            )
            hints.append((-matches, -project_markers, depth, current))
    hints.sort()
    return [path for _matches, _markers, _depth, path in hints[:limit]]


def validated_routed_cwd(output: str, root: str) -> str:
    root = os.path.realpath(root)
    choices = [output.strip().strip("`'\"")]
    choices.extend(line.strip().strip("`'\"") for line in output.splitlines())
    for choice in choices:
        if not choice:
            continue
        selected = os.path.realpath(os.path.expanduser(choice))
        try:
            within_root = os.path.commonpath((root, selected)) == root
        except ValueError:
            within_root = False
        if within_root and os.path.isdir(selected):
            return selected
    raise ValueError("Codex router did not return an existing directory beneath the requested cwd")


def route_cwd_with_codex(prompt: str, cwd: str, model: str, timeout: float) -> str:
    root = os.path.realpath(os.path.abspath(os.path.expanduser(cwd)))
    hints = directory_name_hints(prompt, root)
    hint_text = "\n".join(f"- {path}" for path in hints) if hints else "- No distinctive directory-name matches found."
    router_prompt = (
        "Choose the best working directory beneath the root below for the user's coding-agent session. "
        "Use at most four quick, read-only shell commands and finish the exploration within 20 seconds. "
        "First search directory names to depth four for the request's distinctive names, organizations, "
        "products, and domain terms. Then inspect files only inside the most promising directories; never run "
        "an exhaustive recursive content search over the whole root. Exclude bulky generated directories such "
        "as .git and node_modules. You must run the directory-name search before deciding. A direct match for "
        "a rare domain term from the request (for example GST or tax) always outranks a directory supported "
        "only by generic words such as agent, app, integration, or workflow. Never select a generic agent "
        "framework when a domain-specific match exists. A lightweight directory-name scan has already produced "
        "the evidence paths listed below. When that list is non-empty, inspect those paths first and return one "
        "of them (or a more specific descendant you inspect); do not return an unrelated path. Inspect relevant "
        "nested directories before deciding. "
        "Do not modify anything. "
        "Return exactly one existing absolute directory path beneath the root and nothing else. "
        "Choose the root itself only when no more specific directory is supported by the evidence.\n\n"
        f"Root: {root}\nUser request: {prompt[:4000]}\n\nDistinctive directory-name evidence:\n{hint_text}"
    )
    output_path = ""
    try:
        with tempfile.NamedTemporaryFile(prefix="agent-launch-cwd-", delete=False) as output_file:
            output_path = output_file.name
        cmd = [
            "codex",
            "exec",
            "--ephemeral",
            "--ignore-user-config",
            "--ignore-rules",
            "-s",
            "read-only",
            "-C",
            root,
            "--skip-git-repo-check",
            "--color",
            "never",
            "-m",
            model,
            "-c",
            "model_reasoning_effort=low",
            "-o",
            output_path,
            router_prompt,
        ]
        completed = subprocess.run(
            cmd,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.PIPE,
            text=True,
            timeout=timeout if timeout > 0 else None,
            check=False,
        )
        if completed.returncode != 0:
            raise RuntimeError(f"Codex router exited with status {completed.returncode}")
        with open(output_path, encoding="utf-8") as handle:
            return validated_routed_cwd(handle.read(), root)
    finally:
        if output_path:
            try:
                os.unlink(output_path)
            except OSError:
                pass


def maybe_route_cwd(args: argparse.Namespace) -> None:
    if args.no_auto_cwd or args.non_interactive:
        return
    prompt = prompt_from(args)
    if not prompt or not prompt.strip():
        return

    if truthy_env_disabled(os.environ.get("AGENT_LAUNCH_AUTO_CWD")):
        return
    if not os.path.isdir(os.path.expanduser(args.cwd)) or not shutil.which("codex"):
        return
    model, timeout = cwd_router_config()
    try:
        selected = route_cwd_with_codex(prompt, args.cwd, model, timeout)
    except (OSError, RuntimeError, ValueError, subprocess.TimeoutExpired) as exc:
        if os.environ.get("AGENT_LAUNCH_CWD_ROUTER_DEBUG"):
            print(f"agent-launch auto-cwd skipped: {exc}", file=sys.stderr, flush=True)
        return

    original = os.path.abspath(os.path.expanduser(args.cwd))
    if selected != original:
        print(f"agent-launch auto-cwd: {selected} (selected by Codex {model})", file=sys.stderr, flush=True)
    args.cwd = selected


