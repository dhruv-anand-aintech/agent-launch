#!/usr/bin/env python3
"""Launch common coding-agent CLIs through one normalized interface."""

from __future__ import annotations

import argparse
import copy
import os
import random
import shlex
import shutil
import subprocess
import sys
from dataclasses import dataclass


@dataclass(frozen=True)
class AgentSpec:
    executable: str
    fast_model: str
    pro_model: str
    default_model_class: str = "pro"


AGENTS: dict[str, AgentSpec] = {
    "aider": AgentSpec("aider", "", "", "pro"),
    "amp": AgentSpec("amp", "", "", "pro"),
    "antigravity": AgentSpec("agy", "", "", "pro"),
    "codex": AgentSpec("codex", "gpt-5.4-mini", "gpt-5.5", "pro"),
    "claude": AgentSpec("claude", "haiku", "sonnet", "pro"),
    "cline": AgentSpec("cline", "", "", "pro"),
    "droid": AgentSpec("droid", "claude-opus-4-8-fast", "claude-opus-4-8", "pro"),
    "gemini": AgentSpec("gemini", "gemini-2.5-flash", "gemini-2.5-pro", "pro"),
    "grok": AgentSpec("grok", "", "", "pro"),
    "kilo": AgentSpec("kilo", "", "", "pro"),
    "kimi": AgentSpec("kimi", "", "", "pro"),
    "kiro": AgentSpec("kiro-cli", "", "", "pro"),
    "mimo": AgentSpec("mimo", "", "", "pro"),
    "opencode": AgentSpec("opencode", "opencode-go/deepseek-v4-flash", "opencode-go/kimi-k2.6", "pro"),
    "pi": AgentSpec("pi", "", "", "pro"),
    "qwen": AgentSpec("qwen", "", "", "pro"),
    "cursor": AgentSpec("agent", "composer-2.5-fast", "composer-2.5-fast", "fast"),
}


AGENT_CHOICES = tuple(sorted((*AGENTS.keys(), "random")))
RANDOM_AGENTS = (
    "claude",
    "codex",
    "cursor",
    "opencode",
)
DEFAULT_AGENT_ORDER = (
    "codex",
    "claude",
    "cursor",
    "opencode",
    "antigravity",
    "gemini",
    "aider",
    "amp",
    "cline",
    "droid",
    "grok",
    "kilo",
    "kimi",
    "kiro",
    "mimo",
    "pi",
    "qwen",
)
MODES = ("default", "ask", "plan", "auto", "danger")


def random_state_path() -> str:
    state_home = os.environ.get("XDG_STATE_HOME") or os.path.expanduser("~/.local/state")
    return os.path.join(state_home, "agent-launch", "last-random-agent")


def read_last_random_agent() -> str | None:
    try:
        with open(random_state_path(), encoding="utf-8") as handle:
            last = handle.read().strip()
    except OSError:
        return None
    return last if last in RANDOM_AGENTS else None


def write_last_random_agent(agent: str) -> None:
    path = random_state_path()
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", encoding="utf-8") as handle:
        handle.write(f"{agent}\n")


def is_agent_installed(agent: str) -> bool:
    return shutil.which(AGENTS[agent].executable) is not None


def installed_random_agents() -> tuple[str, ...]:
    return tuple(agent for agent in RANDOM_AGENTS if is_agent_installed(agent))


def choose_random_agent(persist: bool = True) -> str:
    installed = installed_random_agents()
    if not installed:
        executables = ", ".join(f"{agent} ({AGENTS[agent].executable})" for agent in RANDOM_AGENTS)
        raise SystemExit(f"No random-pool agents are installed on PATH. Install at least one of: {executables}")
    pool = list(installed)
    last = read_last_random_agent()
    if last and len(pool) > 1:
        pool = [agent for agent in pool if agent != last]
    if not pool:
        pool = list(installed)
    choice = random.choice(pool)
    if persist:
        write_last_random_agent(choice)
    return choice


MODEL_CLASSES = ("fast", "pro")
MODEL_FLAG_AGENTS = {
    "aider",
    "cline",
    "codex",
    "claude",
    "droid",
    "gemini",
    "grok",
    "kilo",
    "kimi",
    "kiro",
    "mimo",
    "opencode",
    "pi",
    "qwen",
    "cursor",
}


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    argv = list(sys.argv[1:] if argv is None else argv)
    passthrough_args: list[str] = []
    if "--" in argv:
        delimiter_index = argv.index("--")
        passthrough_args = argv[delimiter_index + 1 :]
        argv = argv[:delimiter_index]

    parser = argparse.ArgumentParser(
        prog="agent-launch",
        description="Launch local coding-agent CLIs with a shared interface.",
    )
    parser.add_argument(
        "-a",
        "--agent",
        choices=AGENT_CHOICES,
        default=os.environ.get("AGENT_LAUNCH_AGENT") or "random",
        help="Agent CLI to launch. Use random to select a concrete backend uniformly. Defaults to AGENT_LAUNCH_AGENT or random.",
    )
    parser.add_argument(
        "--agent-order",
        nargs="?",
        const="default",
        default=None,
        help=(
            "Non-interactive failover order as comma-separated agents. "
            "Use without a value for the built-in default, or set AGENT_LAUNCH_AGENT_ORDER."
        ),
    )
    parser.add_argument(
        "--prefer",
        default=None,
        help=(
            "Non-interactive preferred agents as a comma-separated list. "
            "Moves those agents to the front of the default failover order."
        ),
    )
    parser.add_argument(
        "-C",
        "--cwd",
        default=os.getcwd(),
        help="Working directory/workspace for the agent. Defaults to current directory.",
    )
    parser.add_argument(
        "-p",
        "--prompt",
        default=None,
        help="Initial prompt. If omitted, remaining positional text is used.",
    )
    parser.add_argument(
        "--prompt-file",
        default=None,
        help="Read the initial prompt from a UTF-8 text file.",
    )
    parser.add_argument(
        "prompt_parts",
        nargs="*",
        help="Initial prompt text, used when --prompt is not provided.",
    )
    run_mode = parser.add_mutually_exclusive_group()
    run_mode.add_argument(
        "-i",
        "--interactive",
        action="store_true",
        help="Start interactive mode. This is the default.",
    )
    run_mode.add_argument(
        "-n",
        "--non-interactive",
        action="store_true",
        help="Run headless/non-interactively and print output.",
    )
    parser.add_argument(
        "-m",
        "--mode",
        choices=MODES,
        default=os.environ.get("AGENT_LAUNCH_MODE", "danger"),
        help="Normalized permission/interaction mode.",
    )
    parser.add_argument(
        "--model-class",
        choices=MODEL_CLASSES,
        default=None,
        help="Use the agent's normalized fast or pro model. Defaults per agent.",
    )
    parser.add_argument(
        "--model",
        default=None,
        help="Explicit backend model string. Overrides --model-class.",
    )
    parser.add_argument(
        "--no-model",
        action="store_true",
        help="Do not pass any model flag to the backend.",
    )
    parser.add_argument(
        "--resume",
        nargs="?",
        const="",
        default=None,
        help="Resume a prior session. With no value, use the backend's picker/latest behavior where available.",
    )
    parser.add_argument(
        "--continue",
        dest="continue_session",
        action="store_true",
        help="Continue the latest/current session where the selected backend supports it.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the translated command without executing it.",
    )
    parser.add_argument(
        "--attempt-timeout",
        type=float,
        default=float(os.environ.get("AGENT_LAUNCH_ATTEMPT_TIMEOUT", "0") or "0"),
        help="Timeout in seconds for each non-interactive backend attempt. Exit code 124 on timeout.",
    )
    parser.add_argument(
        "--extra",
        action="append",
        default=[],
        help="Extra raw argument chunk to append to the backend command. Prefer '--' for exact pass-through.",
    )
    parser.add_argument(
        "--print-mappings",
        action="store_true",
        help="Print normalized mode/model mappings and exit.",
    )
    args, unknown_args = parser.parse_known_args(argv)
    if args.agent not in AGENT_CHOICES:
        parser.error(f"unknown agent {args.agent!r}; expected one of: {', '.join(AGENT_CHOICES)}")
    if args.resume is not None and args.continue_session:
        parser.error("--resume and --continue cannot be used together")
    if args.prompt_file and (args.prompt is not None or args.prompt_parts):
        parser.error("--prompt-file cannot be combined with --prompt or positional prompt text")
    args.passthrough_args = unknown_args + passthrough_args
    if args.print_mappings:
        args.agent_order = None
        return args
    prefer = parse_agent_list(args.prefer or os.environ.get("AGENT_LAUNCH_PREFER"), "--prefer")
    explicit_order = parse_agent_order(args.agent_order or os.environ.get("AGENT_LAUNCH_AGENT_ORDER"))
    if prefer and explicit_order:
        parser.error("--prefer cannot be combined with --agent-order")
    agent_order = preferred_agent_order(prefer) if prefer else explicit_order
    if agent_order and not args.non_interactive:
        parser.error("--agent-order/--prefer are only supported with --non-interactive")
    args.agent_order = agent_order
    if args.agent == "random" and not args.agent_order:
        args.agent = choose_random_agent(persist=not args.dry_run)
    return args


def parse_agent_order(raw: str | None) -> tuple[str, ...] | None:
    if raw is None:
        return None
    if raw == "" or raw == "default":
        return DEFAULT_AGENT_ORDER
    agents = parse_agent_list(raw, "--agent-order")
    if not agents:
        return DEFAULT_AGENT_ORDER
    return agents


def parse_agent_list(raw: str | None, option_name: str) -> tuple[str, ...] | None:
    if raw is None:
        return None
    agents = tuple(dict.fromkeys(part.strip() for part in raw.split(",") if part.strip()))
    unknown = [agent for agent in agents if agent not in AGENTS]
    if unknown:
        expected = ", ".join(AGENTS)
        raise SystemExit(f"Unknown {option_name} agent(s): {', '.join(unknown)}; expected agents from: {expected}")
    return agents


def preferred_agent_order(preferred: tuple[str, ...] | None) -> tuple[str, ...] | None:
    if not preferred:
        return None
    return preferred + tuple(agent for agent in DEFAULT_AGENT_ORDER if agent not in preferred)


def env_key(agent: str, model_class: str) -> str:
    return f"AGENT_LAUNCH_{agent.upper()}_{model_class.upper()}_MODEL"


def resolve_model_class(agent: str, args: argparse.Namespace) -> str:
    spec = AGENTS[agent]
    model_class = args.model_class or os.environ.get("AGENT_LAUNCH_MODEL_CLASS") or spec.default_model_class
    if model_class not in MODEL_CLASSES:
        raise SystemExit(f"Unknown model class {model_class!r}; expected one of: {', '.join(MODEL_CLASSES)}")
    return model_class


def resolve_model(agent: str, args: argparse.Namespace) -> str | None:
    if args.no_model:
        return None
    if args.model:
        return args.model

    spec = AGENTS[agent]
    model_class = resolve_model_class(agent, args)
    return os.environ.get(env_key(agent, model_class)) or getattr(spec, f"{model_class}_model")


def prompt_from(args: argparse.Namespace) -> str | None:
    if args.prompt_file is not None:
        with open(args.prompt_file, encoding="utf-8") as handle:
            return handle.read()
    if args.prompt is not None:
        return args.prompt
    if args.prompt_parts:
        return " ".join(args.prompt_parts)
    return None


def mode_flags(agent: str, mode: str, non_interactive: bool) -> list[str]:
    if mode == "default":
        return []

    mappings: dict[str, dict[str, list[str]]] = {
        "codex": {
            "ask": ["-s", "read-only"],
            "plan": ["-s", "read-only"],
            "auto": [],
            "danger": ["--dangerously-bypass-approvals-and-sandbox"],
        },
        "claude": {
            "ask": ["--permission-mode", "default"],
            "plan": ["--permission-mode", "plan"],
            "auto": ["--permission-mode", "auto"],
            "danger": ["--dangerously-skip-permissions"],
        },
        "aider": {
            "ask": ["--no-auto-commits"],
            "plan": ["--architect"],
            "auto": ["--yes-always"],
            "danger": ["--yes-always"],
        },
        "amp": {
            "ask": [],
            "plan": [],
            "auto": [],
            "danger": [],
        },
        "antigravity": {
            "ask": [],
            "plan": ["--sandbox"],
            "auto": [],
            "danger": ["--dangerously-skip-permissions"],
        },
        "cline": {
            "ask": ["--auto-approve", "false"],
            "plan": ["--plan"],
            "auto": ["--auto-approve", "true"],
            "danger": ["--auto-approve", "true"],
        },
        "droid": {
            "ask": [],
            "plan": [],
            "auto": ["--auto", "medium"],
            "danger": ["--skip-permissions-unsafe"],
        },
        "gemini": {
            "ask": ["--approval-mode", "default"],
            "plan": ["--approval-mode", "plan"],
            "auto": ["--approval-mode", "auto_edit"],
            "danger": ["--yolo"],
        },
        "grok": {
            "ask": ["--permission-mode", "default"],
            "plan": ["--permission-mode", "plan"],
            "auto": ["--permission-mode", "auto"],
            "danger": ["--permission-mode", "bypassPermissions"],
        },
        "kilo": {
            "ask": ["--agent", "ask"],
            "plan": ["--agent", "plan"],
            "auto": ["--auto"],
            "danger": ["--dangerously-skip-permissions"],
        },
        "kimi": {
            "ask": [],
            "plan": ["--plan"],
            "auto": ["--auto"],
            "danger": ["--yolo"],
        },
        "kiro": {
            "ask": [],
            "plan": [],
            "auto": [],
            "danger": ["--trust-all-tools"],
        },
        "mimo": {
            "ask": ["--agent", "plan"],
            "plan": ["--agent", "plan"],
            "auto": ["--agent", "build"],
            "danger": ["--dangerously-skip-permissions"] if non_interactive else [],
        },
        "opencode": {
            "ask": ["--agent", "ask"],
            "plan": ["--agent", "plan"],
            "auto": [],
            "danger": ["--dangerously-skip-permissions"] if non_interactive else [],
        },
        "pi": {
            "ask": [],
            "plan": [],
            "auto": [],
            "danger": [],
        },
        "qwen": {
            "ask": ["--approval-mode", "default"],
            "plan": ["--approval-mode", "plan"],
            "auto": ["--approval-mode", "auto_edit"],
            "danger": ["--yolo"],
        },
        "cursor": {
            "ask": ["--mode", "ask"],
            "plan": ["--mode", "plan"],
            "auto": ["--force"],
            "danger": ["--yolo", "--sandbox", "disabled"],
        },
    }
    return mappings[agent][mode]


def append_model(cmd: list[str], agent: str, model: str | None) -> None:
    if not model:
        return
    if agent in MODEL_FLAG_AGENTS:
        cmd += ["--model", model]


def append_reasoning_effort(cmd: list[str], agent: str, model_class: str, model: str | None) -> None:
    if agent == "codex" and model_class == "pro" and model == "gpt-5.5":
        cmd += ["-c", "model_reasoning_effort=low"]


def append_passthrough(cmd: list[str], args: argparse.Namespace) -> None:
    for raw in args.extra:
        cmd.extend(shlex.split(raw))
    cmd.extend(args.passthrough_args)


def args_for_agent(args: argparse.Namespace, agent: str) -> argparse.Namespace:
    agent_args = copy.copy(args)
    agent_args.agent = agent
    return agent_args


def build_command(args: argparse.Namespace) -> list[str]:
    agent = args.agent
    spec = AGENTS[agent]
    prompt = prompt_from(args)
    non_interactive = args.non_interactive
    model = resolve_model(agent, args)
    model_class = resolve_model_class(agent, args)
    resume_requested = args.resume is not None
    continue_session = args.continue_session
    resume_id = args.resume if args.resume else None
    cmd = [spec.executable]

    if agent == "aider":
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if prompt:
            if non_interactive:
                cmd += ["--message", prompt]
            else:
                cmd.append(prompt)

    elif agent == "amp":
        append_passthrough(cmd, args)
        if prompt:
            if non_interactive:
                cmd += ["--execute", prompt]
            else:
                cmd.append(prompt)

    elif agent == "codex":
        if resume_requested or continue_session:
            cmd += ["exec" if non_interactive else "resume"]
            if non_interactive:
                cmd += ["resume", "-C", args.cwd, "--skip-git-repo-check"]
            else:
                cmd += ["-C", args.cwd]
            cmd += mode_flags(agent, args.mode, non_interactive)
            append_model(cmd, agent, model)
            append_reasoning_effort(cmd, agent, model_class, model)
            append_passthrough(cmd, args)
            if resume_id:
                cmd.append(resume_id)
            elif continue_session or non_interactive:
                cmd.append("--last")
        else:
            if non_interactive:
                cmd += ["exec", "-C", args.cwd, "--skip-git-repo-check"]
            else:
                cmd += ["-C", args.cwd]
            cmd += mode_flags(agent, args.mode, non_interactive)
            append_model(cmd, agent, model)
            append_reasoning_effort(cmd, agent, model_class, model)
            append_passthrough(cmd, args)
            if prompt:
                cmd.append(prompt)
        if prompt and (resume_requested or continue_session):
            cmd.append(prompt)

    elif agent == "claude":
        cmd += ["--add-dir", args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        cmd += ["--effort", "medium"]
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--resume", resume_id]
        elif continue_session:
            cmd += ["--continue"]
        elif resume_requested:
            cmd += ["--resume"]
        if non_interactive:
            cmd += ["--print"]
        if prompt:
            cmd.append(prompt)

    elif agent == "cline":
        cmd += ["--cwd", args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--id", resume_id]
        elif resume_requested or continue_session:
            # Cline requires an explicit session id to resume from the CLI.
            pass
        if non_interactive:
            cmd += ["--json"]
        if prompt:
            cmd.append(prompt)

    elif agent == "droid":
        if non_interactive:
            cmd += ["exec", "--cwd", args.cwd]
            cmd += mode_flags(agent, args.mode, non_interactive)
            append_model(cmd, agent, model)
            append_passthrough(cmd, args)
            if resume_id:
                cmd += ["--session-id", resume_id]
            if prompt:
                cmd.append(prompt)
        else:
            cmd += ["--cwd", args.cwd]
            append_model(cmd, agent, model)
            append_passthrough(cmd, args)
            if resume_id:
                cmd += ["--resume", resume_id]
            elif resume_requested or continue_session:
                cmd += ["--resume"]
            if prompt:
                cmd.append(prompt)

    elif agent == "antigravity":
        cmd += ["--add-dir", args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_passthrough(cmd, args)
        if resume_requested or continue_session:
            if resume_id:
                cmd += ["--conversation", resume_id]
            else:
                cmd += ["--continue"]
        if prompt:
            if non_interactive:
                cmd += ["--print", prompt]
            else:
                cmd += ["--prompt-interactive", prompt]
        elif non_interactive:
            cmd += ["--print"]

    elif agent == "gemini":
        cmd += ["--include-directories", args.cwd, "--skip-trust"]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_requested or continue_session:
            cmd += ["--resume", resume_id or "latest"]
        if prompt:
            if non_interactive:
                cmd += ["--prompt", prompt]
            else:
                cmd += ["--prompt-interactive", prompt]

    elif agent == "grok":
        cmd += ["--cwd", args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--resume", resume_id]
        elif resume_requested or continue_session:
            cmd += ["--resume"]
        if prompt:
            if non_interactive:
                cmd += ["--single", prompt]
            else:
                cmd.append(prompt)

    elif agent == "kilo":
        if non_interactive:
            cmd += ["run", "--dir", args.cwd]
        else:
            cmd += [args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--session", resume_id]
        elif resume_requested or continue_session:
            cmd += ["--continue"]
        if prompt:
            cmd.append(prompt)

    elif agent == "kimi":
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--session", resume_id]
        elif continue_session:
            cmd += ["--continue"]
        elif resume_requested:
            cmd += ["--session"]
        if prompt:
            if non_interactive:
                cmd += ["--prompt", prompt]
            else:
                cmd.append(prompt)

    elif agent == "kiro":
        cmd += ["chat"]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--resume-id", resume_id]
        elif continue_session:
            cmd += ["--resume"]
        elif resume_requested:
            cmd += ["--resume-picker"]
        if non_interactive:
            cmd += ["--no-interactive"]
        if prompt:
            cmd.append(prompt)

    elif agent == "mimo":
        if non_interactive:
            cmd += ["run"]
        else:
            cmd += [args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--session", resume_id]
        elif resume_requested or continue_session:
            cmd += ["--continue"]
        if prompt:
            if non_interactive:
                cmd.append(prompt)
            else:
                cmd += ["--prompt", prompt]

    elif agent == "opencode":
        if non_interactive:
            cmd += ["run", "--dir", args.cwd]
        else:
            cmd += [args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_requested or continue_session:
            if resume_id:
                cmd += ["--session", resume_id]
            else:
                cmd += ["--continue"]
        if prompt:
            if non_interactive:
                cmd.append(prompt)
            else:
                cmd += ["--prompt", prompt]

    elif agent == "pi":
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--session", resume_id]
        elif resume_requested or continue_session:
            cmd += ["--continue"]
        if non_interactive:
            cmd += ["--print"]
        if prompt:
            cmd.append(prompt)

    elif agent == "qwen":
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_requested or continue_session:
            cmd += ["--resume", resume_id or "latest"]
        if prompt:
            if non_interactive:
                cmd += ["--prompt", prompt]
            else:
                cmd.append(prompt)

    elif agent == "cursor":
        cmd += ["--workspace", args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_requested or continue_session:
            if resume_id:
                cmd += ["--resume", resume_id]
            else:
                cmd += ["--continue"]
        if non_interactive:
            cmd += ["--print", "--trust"]
        if prompt:
            cmd.append(prompt)

    return cmd


def print_mappings() -> None:
    print("Agents:")
    for name, spec in AGENTS.items():
        default_model = getattr(spec, f"{spec.default_model_class}_model")
        if default_model:
            print(
                f"  {name}: executable={spec.executable}, fast={spec.fast_model}, "
                f"pro={spec.pro_model}, default={spec.default_model_class} ({default_model})"
            )
        elif name in MODEL_FLAG_AGENTS:
            print(f"  {name}: executable={spec.executable}, no built-in model default; supports explicit --model")
        else:
            print(f"  {name}: executable={spec.executable}, model flag unsupported")
    print(
        f"  random: uniformly selects one installed backend from {', '.join(RANDOM_AGENTS)} "
        "(never the same as the previous random pick when another installed option exists)"
    )
    print(f"  default order: {', '.join(DEFAULT_AGENT_ORDER)}")
    print("  codex pro: adds -c model_reasoning_effort=low when using gpt-5.5")
    print("\nModes:")
    for mode in MODES:
        print(f"  {mode}")
    print("\nUse --dry-run to inspect exact backend flags for a specific agent/mode.")


def call_command(cmd: list[str], timeout: float = 0) -> int:
    try:
        return subprocess.call(cmd, timeout=timeout if timeout > 0 else None)
    except FileNotFoundError:
        print(f"agent-launch failed: executable not found: {cmd[0]}", file=sys.stderr, flush=True)
        return 127
    except subprocess.TimeoutExpired:
        print(f"agent-launch failed: timed out after {timeout:g}s: {shlex.join(cmd)}", file=sys.stderr, flush=True)
        return 124


def run_command(args: argparse.Namespace, cmd: list[str]) -> int:
    print(f"agent-launch executing: {shlex.join(cmd)}", file=sys.stderr, flush=True)
    os.chdir(args.cwd)
    if args.non_interactive:
        return call_command(cmd, args.attempt_timeout)
    # Replace this wrapper so Codex/Claude/Cursor inherit a real controlling TTY.
    os.execvp(cmd[0], cmd)
    return 127


def run_agent_order(args: argparse.Namespace) -> int:
    os.chdir(args.cwd)
    assert args.agent_order is not None
    last_code = 1
    for index, agent in enumerate(args.agent_order, start=1):
        agent_args = args_for_agent(args, agent)
        cmd = build_command(agent_args)
        print(
            f"agent-launch attempt {index}/{len(args.agent_order)} [{agent}]: {shlex.join(cmd)}",
            file=sys.stderr,
            flush=True,
        )
        last_code = call_command(cmd, args.attempt_timeout)
        if last_code == 0:
            return 0
        print(
            f"agent-launch attempt failed [{agent}] exit={last_code}; trying next agent",
            file=sys.stderr,
            flush=True,
        )
    return last_code


def main() -> int:
    args = parse_args()
    if args.print_mappings:
        print_mappings()
        return 0
    if args.agent_order:
        if args.dry_run:
            for agent in args.agent_order:
                print(shlex.join(build_command(args_for_agent(args, agent))))
            return 0
        return run_agent_order(args)
    cmd = build_command(args)
    if args.dry_run:
        print(shlex.join(cmd))
        return 0
    return run_command(args, cmd)


if __name__ == "__main__":
    raise SystemExit(main())
