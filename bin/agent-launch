ROUTER_IGNORED_DIRS = {".git", ".hg", ".svn", ".venv", "build", "dist", "node_modules", "vendor"}


def random_state_path() -> str:
    state_home = os.environ.get("XDG_STATE_HOME") or os.path.expanduser("~/.local/state")
    return os.path.join(state_home, "agent-launch", "last-random-agent")


def read_last_random_agent() -> str | None:
    try:
        with open(random_state_path(), encoding="utf-8") as handle:
            last = handle.read().strip()
    except OSError:
        return None
    return last if last in RANDOM_AGENTS else None


def write_last_random_agent(agent: str) -> None:
    path = random_state_path()
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", encoding="utf-8") as handle:
        handle.write(f"{agent}\n")


def is_agent_installed(agent: str) -> bool:
    return shutil.which(AGENTS[agent].executable) is not None


def installed_random_agents() -> tuple[str, ...]:
    return tuple(agent for agent in RANDOM_AGENTS if is_agent_installed(agent))


def choose_random_agent(persist: bool = True) -> str:
    installed = installed_random_agents()
    if not installed:
        executables = ", ".join(f"{agent} ({AGENTS[agent].executable})" for agent in RANDOM_AGENTS)
        raise SystemExit(f"No random-pool agents are installed on PATH. Install at least one of: {executables}")
    pool = list(installed)
    last = read_last_random_agent()
    if last and len(pool) > 1:
        pool = [agent for agent in pool if agent != last]
    if not pool:
        pool = list(installed)
    choice = random.choice(pool)
    if persist:
        write_last_random_agent(choice)
    return choice


MODEL_CLASSES = ("fast", "pro")
THINKING_LEVELS = ("auto", "low", "medium", "high")
MODEL_FLAG_AGENTS = {
    "aider",
    "amazonq",
    "cline",
    "codex",
    "claude",
    "copilot",
    "crush",
    "droid",
    "gemini",
    "goose",
    "grok",
