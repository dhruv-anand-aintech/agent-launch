MODES = ("default", "ask", "plan", "auto", "danger")
DEFAULT_CWD_ROUTER_MODEL = "gpt-5.6-luna"
DEFAULT_CWD_ROUTER_TIMEOUT = 45.0
ROUTER_GENERIC_TERMS = {
    "add",
    "and",
    "about",
