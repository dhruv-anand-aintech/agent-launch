            "ask": [],
            "plan": [],
            "auto": ["--trust-tools=fs_read,fs_write,execute_bash"],
            "danger": ["--trust-all-tools"],
        },
        "copilot": {
            "ask": [],
            "plan": ["--plan"],
            "auto": ["--autopilot"],
            "danger": ["--allow-all"],
        },
        "crush": {
            "ask": [],
            "plan": [],
            "auto": [],
            "danger": ["-y"],
        },
        "openhands": {
            "ask": [],
            "plan": [],
            "auto": ["--llm-approve"],
            "danger": ["--always-approve"],
        },
    }
    return mappings[agent][mode]


def append_model(cmd: list[str], agent: str, model: str | None) -> None:
    if not model:
        return
    if agent in MODEL_FLAG_AGENTS:
        cmd += ["--model", model]


def append_thinking_level(cmd: list[str], agent: str, args: argparse.Namespace, model_class: str, model: str | None) -> None:
    level = resolve_thinking_level(args)
    if agent == "codex":
        if level == "auto":
            if model_class == "pro" and model == "gpt-5.6-sol":
                cmd += ["-c", "model_reasoning_effort=medium"]
            return
        cmd += ["-c", f"model_reasoning_effort={level}"]
    elif agent == "claude":
        cmd += ["--effort", "medium" if level == "auto" else level]
    elif agent == "copilot" and level != "auto":
        cmd += [f"--effort={level}"]


def append_passthrough(cmd: list[str], args: argparse.Namespace) -> None:
    for raw in args.extra:
        cmd.extend(shlex.split(raw))
    cmd.extend(args.passthrough_args)


def args_for_agent(args: argparse.Namespace, agent: str) -> argparse.Namespace:
    agent_args = copy.copy(args)
    agent_args.agent = agent
    return agent_args


def build_command(args: argparse.Namespace) -> list[str]:
    agent = args.agent
    spec = AGENTS[agent]
    prompt = prompt_from(args)
    non_interactive = args.non_interactive
    model = resolve_model(agent, args)
    model_class = resolve_model_class(agent, args)
    resume_requested = args.resume is not None
    continue_session = args.continue_session
    resume_id = args.resume if args.resume else None
    cmd = [spec.executable]

    if agent == "aider":
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if prompt:
            if non_interactive:
                cmd += ["--message", prompt]
            else:
                cmd.append(prompt)

    elif agent == "amp":
        append_passthrough(cmd, args)
        if prompt:
            if non_interactive:
                cmd += ["--execute", prompt]
            else:
                cmd.append(prompt)

    elif agent == "codex":
        if resume_requested or continue_session:
            cmd += ["exec" if non_interactive else "resume"]
            if non_interactive:
                cmd += ["resume", "-C", args.cwd, "--skip-git-repo-check"]
            else:
                cmd += ["-C", args.cwd]
            cmd += mode_flags(agent, args.mode, non_interactive)
            append_model(cmd, agent, model)
            append_thinking_level(cmd, agent, args, model_class, model)
            append_passthrough(cmd, args)
            if resume_id:
                cmd.append(resume_id)
            elif continue_session or non_interactive:
                cmd.append("--last")
        else:
            if non_interactive:
                cmd += ["exec", "-C", args.cwd, "--skip-git-repo-check"]
            else:
                cmd += ["-C", args.cwd]
            cmd += mode_flags(agent, args.mode, non_interactive)
            append_model(cmd, agent, model)
            append_thinking_level(cmd, agent, args, model_class, model)
            append_passthrough(cmd, args)
            if prompt:
                cmd.append(prompt)
        if prompt and (resume_requested or continue_session):
            cmd.append(prompt)

    elif agent == "claude":
        cmd += ["--add-dir", args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_thinking_level(cmd, agent, args, model_class, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--resume", resume_id]
        elif continue_session:
            cmd += ["--continue"]
        elif resume_requested:
            cmd += ["--resume"]
        if non_interactive:
            cmd += ["--print"]
        if prompt:
            cmd.append(prompt)

    elif agent == "cline":
        cmd += ["--cwd", args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--id", resume_id]
        elif resume_requested or continue_session:
            # Cline requires an explicit session id to resume from the CLI.
            pass
        if non_interactive:
            cmd += ["--json"]
        if prompt:
            cmd.append(prompt)

    elif agent == "droid":
        if non_interactive:
            cmd += ["exec", "--cwd", args.cwd]
            cmd += mode_flags(agent, args.mode, non_interactive)
            append_model(cmd, agent, model)
            append_passthrough(cmd, args)
            if resume_id:
                cmd += ["--session-id", resume_id]
            if prompt:
                cmd.append(prompt)
        else:
            cmd += ["--cwd", args.cwd]
            append_model(cmd, agent, model)
            append_passthrough(cmd, args)
            if resume_id:
                cmd += ["--resume", resume_id]
            elif resume_requested or continue_session:
                cmd += ["--resume"]
            if prompt:
                cmd.append(prompt)

    elif agent == "antigravity":
        cmd += ["--add-dir", args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_passthrough(cmd, args)
        if resume_requested or continue_session:
            if resume_id:
                cmd += ["--conversation", resume_id]
            else:
                cmd += ["--continue"]
        if prompt:
            if non_interactive:
                cmd += ["--print", prompt]
            else:
                cmd += ["--prompt-interactive", prompt]
        elif non_interactive:
            cmd += ["--print"]

    elif agent == "gemini":
        cmd += ["--include-directories", args.cwd, "--skip-trust"]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_requested or continue_session:
            cmd += ["--resume", resume_id or "latest"]
        if prompt:
            if non_interactive:
                cmd += ["--prompt", prompt]
            else:
                cmd += ["--prompt-interactive", prompt]

    elif agent == "grok":
        cmd += ["--cwd", args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--resume", resume_id]
        elif resume_requested or continue_session:
            cmd += ["--resume"]
        if prompt:
            if non_interactive:
                cmd += ["--single", prompt]
            else:
                cmd.append(prompt)

    elif agent == "kilo":
        if non_interactive:
            cmd += ["run", "--dir", args.cwd]
        else:
            cmd += [args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--session", resume_id]
        elif resume_requested or continue_session:
            cmd += ["--continue"]
        if prompt:
            cmd.append(prompt)

    elif agent == "kimi":
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--session", resume_id]
        elif continue_session:
            cmd += ["--continue"]
        elif resume_requested:
            cmd += ["--session"]
        if prompt:
            if non_interactive:
                cmd += ["--prompt", prompt]
            else:
                cmd.append(prompt)

    elif agent == "kiro":
        cmd += ["chat"]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--resume-id", resume_id]
        elif continue_session:
            cmd += ["--resume"]
        elif resume_requested:
            cmd += ["--resume-picker"]
        if non_interactive:
            cmd += ["--no-interactive"]
        if prompt:
            cmd.append(prompt)

    elif agent == "mimo":
        if non_interactive:
            cmd += ["run"]
        else:
            cmd += [args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--session", resume_id]
        elif resume_requested or continue_session:
            cmd += ["--continue"]
        if prompt:
            if non_interactive:
                cmd.append(prompt)
            else:
                cmd += ["--prompt", prompt]

    elif agent == "opencode":
        if non_interactive:
            cmd += ["run", "--dir", args.cwd]
        else:
            cmd += [args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_requested or continue_session:
            if resume_id:
                cmd += ["--session", resume_id]
            else:
                cmd += ["--continue"]
        if prompt:
            if non_interactive:
                cmd.append(prompt)
            else:
                cmd += ["--prompt", prompt]

    elif agent == "pi":
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--session", resume_id]
        elif resume_requested or continue_session:
            cmd += ["--continue"]
        if non_interactive:
            cmd += ["--print"]
        if prompt:
            cmd.append(prompt)

    elif agent == "pier":
        cmd += ["-C", args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        if resume_requested or continue_session:
            if non_interactive:
                cmd += ["exec", "resume", "--skip-git-repo-check"]
            else:
                cmd += ["resume"]
            append_passthrough(cmd, args)
            if resume_id:
                cmd.append(resume_id)
            else:
                cmd.append("--last")
            if prompt:
                cmd.append(prompt)
        else:
            if non_interactive:
                cmd += ["exec", "--skip-git-repo-check"]
            append_passthrough(cmd, args)
            if prompt:
                cmd.append(prompt)

    elif agent == "qwen":
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_requested or continue_session:
            cmd += ["--resume", resume_id or "latest"]
        if prompt:
            if non_interactive:
                cmd += ["--prompt", prompt]
            else:
                cmd.append(prompt)

    elif agent == "trae":
        if non_interactive or prompt:
            cmd += ["run", "--working-dir", args.cwd]
            cmd += mode_flags(agent, args.mode, non_interactive)
            append_model(cmd, agent, model)
            append_passthrough(cmd, args)
            if prompt:
                cmd.append(prompt)
        else:
            cmd += ["interactive"]
            cmd += mode_flags(agent, args.mode, non_interactive)
            append_model(cmd, agent, model)
            append_passthrough(cmd, args)

    elif agent == "amazonq":
        cmd += ["chat"]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_requested or continue_session:
            cmd += ["--resume"]
        if non_interactive:
            cmd += ["--no-interactive"]
        if prompt:
            cmd.append(prompt)

    elif agent == "copilot":
        cmd += ["-C", args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_thinking_level(cmd, agent, args, model_class, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--resume", resume_id]
        elif continue_session:
            cmd += ["--continue"]
        elif resume_requested:
            cmd += ["--resume"]
        if non_interactive:
            if "--allow-all" not in cmd and "--allow-all-tools" not in cmd:
                cmd += ["--allow-all-tools"]
            if prompt:
                cmd += ["-p", prompt]
        elif prompt:
            cmd += ["-i", prompt]

    elif agent == "crush":
        if non_interactive:
            cmd += ["run"]
        else:
            # --yolo/-y is a root-only flag; `crush run` rejects it outright.
            cmd += mode_flags(agent, args.mode, non_interactive)
        cmd += ["-c", args.cwd]
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--session", resume_id]
        elif resume_requested or continue_session:
            cmd += ["--continue"]
        if non_interactive and prompt:
            cmd.append(prompt)

    elif agent == "goose":
        env_mode = {
            "default": None,
            "ask": "approve",
            "plan": "chat",
            "auto": "smart_approve",
            "danger": "auto",
        }[args.mode]
        if env_mode:
            cmd = ["env", f"GOOSE_MODE={env_mode}", spec.executable]
        cmd += ["run"]
        cmd += ["--quiet"] if non_interactive else ["--interactive"]
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--resume", "--name", resume_id]
        elif resume_requested or continue_session:
            cmd += ["--resume"]
        if prompt:
            cmd += ["--text", prompt]

    elif agent == "openhands":
        if model:
            cmd = ["env", f"LLM_MODEL={model}", spec.executable]
        if non_interactive:
            cmd += ["--headless"]
        cmd += mode_flags(agent, args.mode, non_interactive)
        if model:
            cmd += ["--override-with-envs"]
        append_passthrough(cmd, args)
        if resume_id:
            cmd += ["--resume", resume_id]
        elif continue_session:
            cmd += ["--resume", "--last"]
        elif resume_requested:
            cmd += ["--resume"]
        if prompt:
            cmd += ["-t", prompt]

    elif agent == "cursor":
        cmd += ["--workspace", args.cwd]
        cmd += mode_flags(agent, args.mode, non_interactive)
        append_model(cmd, agent, model)
        append_passthrough(cmd, args)
        if resume_requested or continue_session:
            if resume_id:
                cmd += ["--resume", resume_id]
            else:
                cmd += ["--continue"]
        if non_interactive:
            cmd += ["--print", "--trust"]
        if prompt:
            cmd.append(prompt)

    return cmd


def print_mappings() -> None:
    print("Agents:")
    for name, spec in AGENTS.items():
        default_model = getattr(spec, f"{spec.default_model_class}_model")
        if default_model:
            print(
                f"  {name}: executable={spec.executable}, fast={spec.fast_model}, "
                f"pro={spec.pro_model}, default={spec.default_model_class} ({default_model})"
            )
        elif name in MODEL_FLAG_AGENTS:
            print(f"  {name}: executable={spec.executable}, no built-in model default; supports explicit --model")
        elif name == "openhands":
            print(f"  {name}: executable={spec.executable}, no --model flag; --model sets LLM_MODEL env + --override-with-envs")
        else:
            print(f"  {name}: executable={spec.executable}, model flag unsupported")
    print(
        f"  random: uniformly selects one installed backend from {', '.join(RANDOM_AGENTS)} "
        "(never the same as the previous random pick when another installed option exists)"
    )
    print(f"  default order: {', '.join(DEFAULT_AGENT_ORDER)}")
    print("  thinking levels: auto, low, medium, high")
    print("  codex: --thinking-level maps to -c model_reasoning_effort=<level>; auto keeps gpt-5.6-sol pro at medium")
    print("  claude: --thinking-level maps to --effort <level>; auto uses medium")
    print("  copilot: --thinking-level maps to --effort=<level> when explicitly set")
    print("\nModes:")
    for mode in MODES:
        print(f"  {mode}")
    print("\nUse --dry-run to inspect exact backend flags for a specific agent/mode.")


def call_command(cmd: list[str], timeout: float = 0) -> int:
    try:
        return subprocess.call(cmd, timeout=timeout if timeout > 0 else None)
    except FileNotFoundError:
        print(f"agent-launch failed: executable not found: {cmd[0]}", file=sys.stderr, flush=True)
        return 127
    except subprocess.TimeoutExpired:
        print(f"agent-launch failed: timed out after {timeout:g}s: {shlex.join(cmd)}", file=sys.stderr, flush=True)
        return 124


def run_command(args: argparse.Namespace, cmd: list[str]) -> int:
    print(f"agent-launch executing: {shlex.join(cmd)}", file=sys.stderr, flush=True)
    os.chdir(args.cwd)
    if args.non_interactive:
        return call_command(cmd, args.attempt_timeout)
    # Replace this wrapper so Codex/Claude/Cursor inherit a real controlling TTY.
    os.execvp(cmd[0], cmd)
    return 127


def run_agent_order(args: argparse.Namespace) -> int:
    os.chdir(args.cwd)
    assert args.agent_order is not None
    last_code = 1
    for index, agent in enumerate(args.agent_order, start=1):
        agent_args = args_for_agent(args, agent)
        cmd = build_command(agent_args)
        print(
            f"agent-launch attempt {index}/{len(args.agent_order)} [{agent}]: {shlex.join(cmd)}",
            file=sys.stderr,
            flush=True,
        )
        last_code = call_command(cmd, args.attempt_timeout)
        if last_code == 0:
            return 0
        print(
            f"agent-launch attempt failed [{agent}] exit={last_code}; trying next agent",
            file=sys.stderr,
            flush=True,
        )
    return last_code


def main() -> int:
    args = parse_args()
    if args.print_mappings:
        print_mappings()
        return 0
    maybe_route_cwd(args)
    if args.agent_order:
        if args.dry_run:
            for agent in args.agent_order:
                print(shlex.join(build_command(args_for_agent(args, agent))))
            return 0
        return run_agent_order(args)
    cmd = build_command(args)
    if args.dry_run:
        print(shlex.join(cmd))
        return 0
    return run_command(args, cmd)


if __name__ == "__main__":
    raise SystemExit(main())
